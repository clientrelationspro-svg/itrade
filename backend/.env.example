# Server
APP_NAME=AI外贸工作平台
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_trade_platform
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_trade_platform

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SiliconFlow AI
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# AI Models
AI_MODEL_DAILY=Qwen/Qwen2.5-7B-Instruct
AI_MODEL_COMPLEX=deepseek-ai/DeepSeek-V2.5
AI_MODEL_VISION=Qwen/Qwen2.5-VL-72B-Instruct
AI_MODEL_EMBED_ZH=BAAI/bge-large-zh-v1.5
AI_MODEL_EMBED_EN=BAAI/bge-large-en-v1.5
AI_MODEL_IMAGE=stabilityai/stable-diffusion-3.5-large

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Redis
REDIS_URL=redis://localhost:6379/0
